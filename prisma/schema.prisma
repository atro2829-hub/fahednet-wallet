generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER SYSTEM
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String   @default("")
  phone         String   @default("")
  userId        String   @unique              // 10XXXX format (6 digits), used for transactions
  name          String   @default("")
  avatar        String   @default("")
  role          String   @default("user")      // user | admin | employee
  kycStatus     String   @default("pending")   // pending | submitted | verified | rejected
  kycIdNumber   String   @default("")
  kycIdPhoto    String   @default("")          // base64
  kycSelfie     String   @default("")          // base64
  isBlocked     Boolean  @default(false)
  blockReason   String   @default("")
  fcmToken      String   @default("")
  theme         String   @default("light")     // light | dark
  language      String   @default("ar")        // ar | en
  balanceYER    Float    @default(0)
  balanceSAR    Float    @default(0)
  balanceUSD    Float    @default(0)
  cardType      String   @default("")           // بطاقة شخصية | جواز سفر | رخصة قيادة
  cardNumber    String   @default("")
  cardIssuedAt  String   @default("")           // where the card was issued
  governorate   String   @default("")           // Southern Yemen governorate
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactionsFrom Transaction[] @relation("FromTransaction")
  transactionsTo   Transaction[] @relation("ToTransaction")
  notifications    Notification[]
  sessions         Session[]
  auditLogs        AuditLog[]
  employee         Employee?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String   @default("")
  ip        String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// EMPLOYEE & ROLES SYSTEM
// ============================================================

model Employee {
  id          String   @id @default(cuid())
  userId      String   @unique               // Link to User record
  displayName String   @default("")
  role        String   @default("employee")   // employee | supervisor | manager
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions EmployeePermission[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployeePermission {
  id         String   @id @default(cuid())
  employeeId String
  module     String                        // e.g. "users", "deposit", "withdraw", "orders", "services", "settings", "reports", "support"
  canView    Boolean  @default(false)
  canCreate  Boolean  @default(false)
  canEdit    Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canApprove Boolean  @default(false)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, module])
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  amount      Float
  currency    String   // YER | SAR | USD
  type        String   // transfer | deposit | withdraw | payment | recharge | bill | purchase | code_redemption
  status      String   @default("pending") // pending | completed | failed | refunded | cancelled
  description String   @default("")
  reference   String   @default("")        // Transaction reference number
  metadata    String   @default("")        // JSON string for extra data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fromUser User @relation("FromTransaction", fields: [fromUserId], references: [id])
  toUser   User @relation("ToTransaction", fields: [toUserId], references: [id])
}

// ============================================================
// ENTERTAINMENT SERVICES SYSTEM
// ============================================================

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String
  nameEn      String   @default("")
  icon        String   @default("")
  color       String   @default("#E60000")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  type        String   @default("wallet")   // wallet | api_provider
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services Service[]
}

model Service {
  id           String   @id @default(cuid())
  categoryId   String
  name         String
  nameEn       String   @default("")
  icon         String   @default("")
  color        String   @default("#E60000")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  type         String   @default("code")    // code | api | manual
  instructions String   @default("")         // Usage instructions for customers (e.g., how to redeem PUBG code)
  instructionsEn String @default("")
  apiEndpoint  String   @default("")         // For API-based services
  apiMethod    String   @default("POST")
  apiHeaders   String   @default("")         // JSON
  apiBodyTemplate String @default("")        // JSON template with {quantity}, {phone}, etc.
  apiResponseFormat String @default("")      // JSON path to extract code/pin from response
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  packages    ServicePackage[]
  codes       ProductCode[]
}

model ServicePackage {
  id          String   @id @default(cuid())
  serviceId   String
  name        String                         // e.g., "60 UC", "325 UC", "660 UC"
  nameEn      String   @default("")
  price       Float
  currency    String   @default("YER")
  costPrice   Float    @default(0)           // Cost price for admin profit tracking
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  codes   ProductCode[]
}

model ProductCode {
  id          String   @id @default(cuid())
  serviceId   String                         // Direct link to service for quick lookup
  packageId   String
  code        String                         // The actual code/pin
  serial      String   @default("")          // Serial number if applicable
  status      String   @default("available") // available | sold | reserved | expired
  soldTo      String   @default("")          // User ID who purchased
  soldAt      DateTime?
  orderId     String   @default("")          // Reference to order
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  service Service        @relation(fields: [serviceId], references: [id])
  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, status])
  @@index([code])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // info | transaction | security | promo
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// BILLS
// ============================================================

model BillPayment {
  id          String   @id @default(cuid())
  userId      String
  billType    String   // electricity | water | internet | gas | phone
  billNumber  String
  amount      Float
  currency    String   @default("YER")
  status      String   @default("pending") // pending | paid | failed
  paidAt      DateTime?
  createdAt   DateTime @default(now())
}

// ============================================================
// SYSTEM SETTINGS (Admin)
// ============================================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

// ============================================================
// OTP VERIFICATION
// ============================================================

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @default("")
  action    String
  details   String   @default("")
  ip        String   @default("")
  module    String   @default("")     // users | transactions | services | settings | security | auth
  severity  String   @default("info") // info | warning | critical
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ============================================================
// APP BRANDING & CUSTOMIZATION
// ============================================================

model AppBranding {
  id              String   @id @default(cuid())
  key             String   @unique            // app_icon | splash_image | card_bg_image | primary_color | secondary_color | app_name | app_name_en
  value           String   @default("")       // base64 image or hex color or text
  updatedAt       DateTime @updatedAt
}
